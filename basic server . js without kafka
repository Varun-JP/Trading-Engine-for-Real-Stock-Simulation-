import express from 'express';

const app = express();
const PORT = 5000;

app.use(express.json());


//SIMULATED STREAM PIPELINE : An empty array acting as our local message queue 
let transactionQueue = [] ;

//1 . THE INGESTION ROUTE (The Producer)
// Its only job is to recieve the trade tick and dump it into our queue instantly 

app.post('/api/ticker',(req , res) => { 

const tradeTick = req.body;

//push the raw financial packet into our local queue array
transactionQueue.push(tradeTick);

//Reply immedately to the client that the data packet has been ingested successfully
return res.status(202).json({
    success: true ,
    message : "Trade tick queued for processing"
});

});

//2. THE BACKGROUND ANALYTICS WORKER (The Consumer Simulation)
//this loop runs continously every 3 seconds completely isolated from the route above.

setInterval(() => {
    if(transactionQueue.length > 0){
        console.log(`\n Background Worker : Processing ${transactionQueue.length} pending trade ticks...`);
        //Loop through everything currently inside our queue array
        
        transactionQueue.forEach((tick) => {
            console.log(`[CALCULATING METRICS] Ticker : ${tick.ticker} | Price : rs${tick.price} | Side : ${tick.side}`);
            // (Later , this is where we will write algorithms to calculate the moving averages )
        });
        
        //Clear the queue completely after processing so it's ready for the next batch
        transactionQueue = [];
        console.log("Queue cleared . System resting \n");


    }

} , 3000);  //3000 ms = 3 seconds
//START : Tell the server to start listening on PORT 500
app.listen(PORT , () => {
    console.log(`INGESTION SERVER IS LIVE ON http://localhost:${PORT}`);
});



